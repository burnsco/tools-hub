{
  "name": "tools-hub",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint-staged": "lint-staged",
    "check": "astro check",
    "prepare": "husky",
    "deploy": "bun run build && bunx wrangler deploy",
    "deploy:prod": "bun run deploy",
    "cf:status": "../scripts/cf-portfolio.sh status tools-hub"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.3",
    "astro": "^7.0.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@tailwindcss/postcss": "^4.3.2",
    "autoprefixer": "^10.5.2",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "postcss": "^8.5.16",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "wrangler": "^4.105.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "oxlint --fix",
      "oxfmt"
    ]
  },
  "packageManager": "bun@1.3.11"
}
