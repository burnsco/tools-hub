---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Tools Hub">
  <div class="welcome-container">
    <div class="logo-wrapper">
      <div class="logo-visual" aria-hidden="true">
        <div class="blob blob-1"></div>
        <div class="blob blob-2"></div>
        <div class="blob blob-3"></div>
        <div class="grid-overlay"></div>
      </div>
      <div class="logo-content">
        <div class="logo-badge">Professional Utility Suite</div>
        <h1 class="logo-text">
          DEV TOOLS<br />
          <span class="text-gradient">HUB</span>
        </h1>
        <div class="logo-decoration">
          <div class="line"></div>
          <div class="dot"></div>
          <div class="line"></div>
        </div>
      </div>
    </div>
  </div>
</Layout>

<style>
  .welcome-container {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 100%;
    width: 100%;
    padding: 1rem;
  }

  .logo-wrapper {
    position: relative;
    width: 100%;
    max-width: 900px;
    aspect-ratio: 16 / 9;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #0b1b24;
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 3rem;
    overflow: hidden;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
  }

  .logo-content {
    position: relative;
    z-index: 10;
    text-align: center;
  }

  .logo-badge {
    display: inline-block;
    padding: 0.5rem 1.25rem;
    border-radius: 999px;
    background: rgba(45, 212, 191, 0.1);
    border: 1px solid rgba(45, 212, 191, 0.2);
    color: #2dd4bf;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 2rem;
    animation: fade-in 1s ease-out;
  }

  .logo-text {
    font-size: clamp(3rem, 10vw, 6rem);
    font-weight: 900;
    line-height: 0.95;
    letter-spacing: -0.05em;
    color: white;
    margin: 0;
    animation: scale-in 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .logo-decoration {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    margin-top: 2.5rem;
    opacity: 0.5;
  }

  .logo-decoration .line {
    height: 1px;
    width: 60px;
    background: linear-gradient(90deg, transparent, #2dd4bf, transparent);
  }

  .logo-decoration .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #2dd4bf;
    box-shadow: 0 0 10px #2dd4bf;
  }

  .logo-visual {
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .grid-overlay {
    position: absolute;
    inset: 0;
    background-image: linear-gradient(rgba(255, 255, 255, 0.02) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.02) 1px, transparent 1px);
    background-size: 50px 50px;
    mask-image: radial-gradient(circle at 50% 50%, black, transparent 90%);
  }

  .blob {
    position: absolute;
    width: 500px;
    height: 500px;
    filter: blur(100px);
    border-radius: 50%;
    opacity: 0.2;
    animation: blob-float 25s infinite alternate ease-in-out;
  }

  .blob-1 {
    top: -10%;
    left: -10%;
    background: #0ea5a4;
  }

  .blob-2 {
    bottom: -15%;
    right: -10%;
    background: #6366f1;
    animation-delay: -7s;
  }

  .blob-3 {
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background: #f59e0b;
    width: 400px;
    height: 400px;
    opacity: 0.1;
    animation-duration: 18s;
  }

  @keyframes blob-float {
    0% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(50px, -70px) scale(1.1); }
    66% { transform: translate(-40px, 40px) scale(0.9); }
    100% { transform: translate(0, 0) scale(1); }
  }

  @keyframes scale-in {
    from { opacity: 0; transform: scale(0.9); }
    to { opacity: 1; transform: scale(1); }
  }

  @keyframes fade-in {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @media (max-width: 640px) {
    .logo-wrapper {
      aspect-ratio: 1 / 1;
      border-radius: 2rem;
    }
    
    .logo-text {
      font-size: 4rem;
    }
    
    .logo-decoration .line {
      width: 40px;
    }
  }
</style>
