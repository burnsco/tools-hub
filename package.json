    "predeploy": "bun run build",
    "deploy": "scripts/deploy-pages.sh",
    "deploy:prod": "scripts/deploy-pages.sh main"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.1",
    "astro": "^6.0.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.7",
    "@tailwindcss/postcss": "^4.2.1",
    "autoprefixer": "^10.4.27",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "oxfmt": "^0.37.0",
    "oxlint": "^1.52.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "wrangler": "^4.71.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "oxlint --fix",
      "oxfmt"
    ]
