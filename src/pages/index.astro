---
import Layout from "../layouts/Layout.astro";
import { tools } from "../config/tools";
import ToolCard from "../components/ui/ToolCard.astro";
import ToolGrid from "../components/ui/ToolGrid.astro";

const categories = ["dev", "general", "productivity", "fun", "creative"] as const;
const grouped = tools.reduce(
  (acc, tool) => {
    const bucket = acc[tool.category] ?? [];
    bucket.push(tool);
    acc[tool.category] = bucket;
    return acc;
  },
  {} as Record<string, typeof tools>
);

const categoryLabels: Record<string, string> = {
  dev: "Developer Tools",
  general: "Security & General",
  productivity: "Productivity",
  fun: "Fun & Games",
  creative: "Creative",
};
---

<Layout title="Tools Hub">
  <div class="ui-page">
    <section class="hero-container">
      <div class="hero-content">
        <div class="hero-badge">All-in-one Utility Hub</div>
        <h1 class="hero-title">
          DEV TOOLS <span class="text-gradient">HUB</span>
        </h1>
        <p class="hero-subtitle">
          Professional grade utilities for modern workflows. Fast, private, and always available.
        </p>
      </div>
      <div class="hero-visual" aria-hidden="true">
        <div class="blob blob-1"></div>
        <div class="blob blob-2"></div>
        <div class="blob blob-3"></div>
        <div class="grid-overlay"></div>
      </div>
    </section>

    <div class="content-sections">
      {
        categories.map(
          (cat) =>
            grouped[cat] && (
              <section class="tool-section">
                <div class="section-header">
                  <h2 class="section-title">{categoryLabels[cat]}</h2>
                  <div class="section-line" />
                </div>
                <ToolGrid cols={3}>
                  {grouped[cat].map((tool) => (
                    <ToolCard
                      title={tool.name}
                      href={tool.path}
                      description={tool.description}
                      icon={tool.icon}
                    />
                  ))}
                </ToolGrid>
              </section>
            )
        )
      }
    </div>
  </div>
</Layout>

<style>
  .hero-container {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 420px;
    padding: 3rem 1.5rem;
    margin-bottom: 2.5rem;
    border-radius: 2.5rem;
    background: #0b1b24;
    border: 1px solid rgba(255, 255, 255, 0.05);
    overflow: hidden;
    text-align: center;
  }

  .hero-content {
    position: relative;
    z-index: 10;
    max-width: 800px;
  }

  .hero-badge {
    display: inline-block;
    padding: 0.5rem 1.25rem;
    border-radius: 999px;
    background: rgba(45, 212, 191, 0.1);
    border: 1px solid rgba(45, 212, 191, 0.2);
    color: #2dd4bf;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
    animation: fade-in-up 0.6s ease-out;
  }

  .hero-title {
    font-size: clamp(2.5rem, 8vw, 5rem);
    font-weight: 900;
    line-height: 1.1;
    letter-spacing: -0.04em;
    color: white;
    margin-bottom: 1.5rem;
    animation: fade-in-up 0.8s ease-out;
  }

  .hero-subtitle {
    font-size: clamp(1rem, 2vw, 1.25rem);
    color: #94a3b8;
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.6;
    animation: fade-in-up 1s ease-out;
  }

  .hero-visual {
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .grid-overlay {
    position: absolute;
    inset: 0;
    background-image: linear-gradient(rgba(255, 255, 255, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.03) 1px, transparent 1px);
    background-size: 40px 40px;
    mask-image: radial-gradient(circle at 50% 50%, black, transparent 80%);
  }

  .blob {
    position: absolute;
    width: 400px;
    height: 400px;
    background: #0ea5a4;
    filter: blur(80px);
    border-radius: 50%;
    opacity: 0.15;
    animation: blob-float 20s infinite alternate cubic-bezier(0.45, 0, 0.55, 1);
  }

  .blob-1 {
    top: -100px;
    left: -100px;
    background: #0ea5a4;
  }

  .blob-2 {
    bottom: -150px;
    right: -100px;
    background: #6366f1;
    animation-delay: -5s;
  }

  .blob-3 {
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background: #f59e0b;
    width: 300px;
    height: 300px;
    opacity: 0.08;
    animation-duration: 15s;
  }

  .content-sections {
    display: flex;
    flex-direction: column;
    gap: 4rem;
    padding-bottom: 4rem;
  }

  .section-header {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .section-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: white;
    white-space: nowrap;
  }

  .section-line {
    height: 1px;
    flex: 1;
    background: linear-gradient(90deg, rgba(255, 255, 255, 0.1), transparent);
  }

  @keyframes blob-float {
    0% {
      transform: translate(0, 0) scale(1);
    }
    33% {
      transform: translate(30px, -50px) scale(1.1);
    }
    66% {
      transform: translate(-20px, 20px) scale(0.9);
    }
    100% {
      transform: translate(0, 0) scale(1);
    }
  }

  @keyframes fade-in-up {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 640px) {
    .hero-container {
      min-height: 320px;
      padding: 2rem 1rem;
      border-radius: 1.5rem;
    }
    
    .content-sections {
      gap: 2.5rem;
    }
  }
</style>
